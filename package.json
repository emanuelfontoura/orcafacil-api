{
  "name": "orcafacil-api",
  "version": "1.0.0",
  "description": "API do OrçaFácil - Sistema para gestão de orçamentos, clientes e vendas.",
  "main": "index.js",
  "scripts": {
    "dev:up": "docker compose --env-file .env -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    
    "test:unit": "vitest run ./tests/unit",

    "test:up": "docker compose --env-file .env.test -f docker-compose.test.yml up -d --build",
    "test:migrate": "docker compose --env-file .env.test -f docker-compose.test.yml exec api_test npx prisma migrate deploy",
    "test:e2e:run": "docker compose --env-file .env.test -f docker-compose.test.yml exec api_test npx vitest run ./tests/e2e",
    "test:e2e": "npm run test:up && npm run test:migrate && npm run test:e2e:run",
    "test:integration:run": "docker compose --env-file .env.test -f docker-compose.test.yml exec api_test npx vitest run ./tests/integration",
    "test:integration": "npm run test:up && npm run test:migrate && npm run test:integration:run",
    "test:down": "docker compose -f docker-compose.test.yml down",

    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emanuelfontoura/orcafacil-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/emanuelfontoura/orcafacil-api/issues"
  },
  "homepage": "https://github.com/emanuelfontoura/orcafacil-api#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "nodemon": "^3.1.14",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
